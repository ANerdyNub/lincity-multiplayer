	  -c -o lcsvga-screen.obj `if test -f 'screen.c'; then $(CYGPATH_W) 'screen.c'; else $(CYGPATH_W) '$(srcdir)/screen.c'; fi`; \
	then mv -f "$(DEPDIR)/lcsvga-screen.Tpo" "$(DEPDIR)/lcsvga-screen.Po"; \
	else rm -f "$(DEPDIR)/lcsvga-screen.Tpo"; exit 1; \
	fi
#	source='screen.c' object='lcsvga-screen.obj' libtool=no \
#	depfile='$(DEPDIR)/lcsvga-screen.Po' tmpdepfile='$(DEPDIR)/lcsvga-screen.TPo' \
#	$(CCDEPMODE) $(depcomp) \
#	$(CC) $(DEFS) $(DEFAULT_INCLUDES) $(INCLUDES) $(liblcsvga_la_CPPFLAGS) $(CPPFLAGS) $(AM_CFLAGS) $(CFLAGS) -c -o lcsvga-screen.obj `if test -f 'screen.c'; then $(CYGPATH_W) 'screen.c'; else $(CYGPATH_W) '$(srcdir)/screen.c'; fi`

